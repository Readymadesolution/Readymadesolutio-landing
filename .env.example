# Cal.com API key (server-only, never exposed to the client) — create at https://app.cal.com/settings/developer/api-keys
CAL_API_KEY=
# Numeric ID of the Cal.com event type used for the 30-minute consultation
CAL_EVENT_TYPE_ID=
# Cal.com webhook signing secret (verifies /api/cal/webhook). Set the same value in the Cal.com webhook settings.
CAL_WEBHOOK_SECRET=

# Neon Postgres — pooled connection string (Neon console → Connect)
DATABASE_URL=
# Primary team that owns inbound consultation leads
DEFAULT_TEAM_ID=
